# Server
PORT=8866
HOST=0.0.0.0
NODE_ENV=production

# Data: auto | espn | apifootball
# auto = ESPN board + enrich lineups with API-Football when key is set
DATA_PROVIDER=auto

# Optional: real lineups / fixtures (https://www.api-football.com/)
API_FOOTBALL_KEY=

# Optional: Grok AI narrative (https://console.x.ai)
XAI_API_KEY=
XAI_MODEL=grok-4.5

# Optional: The Odds API (https://the-odds-api.com) — real bookmaker odds
ODDS_API_KEY=
ODDS_REGIONS=uk,eu

# Live WebSocket server poll interval (ms)
LIVE_POLL_MS=5000
